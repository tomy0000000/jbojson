{
  "$id": "https://schema.tomy.tech/airline.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Airline Information",
  "properties": {
    "$id": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    },
    "aerolopa": {
      "description": "The AeroLOPA URL for the airline's seat maps",
      "format": "uri",
      "type": "string"
    },
    "alliance": {
      "description": "The airline alliance the airline belongs to",
      "enum": [
        null,
        "One World",
        "SkyTeam",
        "Star Alliance",
        "Value Alliance"
      ],
      "type": [
        "null",
        "string"
      ]
    },
    "appleWalletPass": {
      "description": "Whether the airline supports Apple Wallet boarding passes",
      "enum": [
        true,
        null
      ],
      "type": [
        "boolean",
        "null"
      ]
    },
    "countries": {
      "description": "The ISO 3166-1 alpha-2 country codes the airline operates from",
      "items": {
        "description": "An ISO 3166-1 alpha-2 country code in lowercase",
        "pattern": "^[a-z]{2}$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "defunct": {
      "description": "Whether the airline has ceased operations",
      "type": "boolean"
    },
    "iata": {
      "description": "The IATA airline designator",
      "pattern": "^[A-Z0-9]{2}$",
      "type": "string"
    },
    "icao": {
      "description": "The ICAO airline designator",
      "pattern": "^[A-Z]{3}$",
      "type": "string"
    },
    "inFlightEntertainment": {
      "description": "The URL to the airline's in-flight entertainment portal",
      "format": "uri",
      "type": "string"
    },
    "internet": {
      "description": "The in-flight internet connectivity providers the airline uses",
      "items": {
        "additionalProperties": false,
        "description": "An in-flight internet connectivity provider",
        "properties": {
          "aircraft": {
            "description": "The aircraft types the provider is available on",
            "items": {
              "description": "An aircraft type designator",
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "name": {
            "description": "The name of the internet connectivity provider",
            "type": "string"
          },
          "url": {
            "description": "The URL to the provider's page for this airline",
            "format": "uri",
            "type": "string"
          }
        },
        "required": [
          "name",
          "url"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "lcc": {
      "description": "Whether the airline is a low-cost carrier",
      "type": "boolean"
    },
    "name": {
      "description": "The airline's name",
      "type": "string"
    },
    "offers": {
      "description": "Promotional flight deals or offers the airline publishes",
      "items": {
        "additionalProperties": false,
        "description": "A promotional flight deal or offer",
        "properties": {
          "name": {
            "description": "The name of the offer",
            "type": "string"
          },
          "url": {
            "description": "The URL to the offer",
            "format": "uri",
            "type": "string"
          }
        },
        "required": [
          "name",
          "url"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "seatguru": {
      "description": "The SeatGuru URL for the airline",
      "format": "uri",
      "type": [
        "null",
        "string"
      ]
    },
    "url": {
      "description": "The airline's official website",
      "format": "uri",
      "type": "string"
    },
    "wikipedia": {
      "description": "The Wikipedia URL for the airline",
      "format": "uri",
      "type": "string"
    }
  },
  "required": [
    "$id",
    "$schema",
    "alliance",
    "countries",
    "defunct",
    "iata",
    "icao",
    "lcc",
    "name",
    "seatguru",
    "url",
    "wikipedia"
  ],
  "title": "Airline",
  "type": "object"
}
